# NextAuth.js – optional if using Supabase Auth only
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Supabase – required for registration and sign-in
# Project URL and keys: Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tkkelpokwmlicuosyhuo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket names (optional). Must match the bucket names in Supabase Storage exactly.
# If your buckets are named "Resources" and "Admin Resources", set:
# BUCKET_RESOURCES=Resources
# BUCKET_ADMIN_RESOURCES=Admin Resources
# Defaults: resources, admin-resources

# Database – transaction pooler (for migrations / direct SQL). Do not commit the real password.
# Get password from Dashboard → Settings → Database. Use port 6543 for transaction pooler.
# Use %40 for @ in password so the URL parses correctly
DATABASE_URL=postgresql://postgres.tkkelpokwmlicuosyhuo:Rogsldp%4026!@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
